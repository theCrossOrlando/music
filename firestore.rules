rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lyrics + scripture are read publicly (e.g. a projection/display surface),
    // but only an authenticated admin (Google sign-in) may create or modify them.
    // To lock writes to specific admins, replace `request.auth != null` with:
    //   request.auth != null && request.auth.uid in ['UID_1', 'UID_2']
    match /lyrics/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /scripture/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny access to anything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
